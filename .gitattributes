# Treat these as binary: never apply text/EOL normalization (which corrupts them)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.avif  binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.pdf   binary
*.zip   binary

# Normalise line endings for text/code to LF
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
